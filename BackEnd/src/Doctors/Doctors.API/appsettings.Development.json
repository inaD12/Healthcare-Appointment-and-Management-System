{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.IdentityModel": "Debug",
      "Microsoft.IdentityModel.Protocols": "Debug"
    }
  },
  "JwtBearerOptions": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [ "http://localhost:5000/auth/realms/hams", "http://localhost:18080/realms/hams"]
    },
    "MetadataAddress": "http://keycloak:8080/realms/hams/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://keycloak:8080/health"
  },
  "OllamaOptions": {
    "Url": "http://ollama:11434/",
    "Model": "mxbai-embed-large"
  }
}
